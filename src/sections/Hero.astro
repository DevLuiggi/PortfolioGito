---
import CodeEditor from '../components/CodeEditor.astro';
import TechBadge from '../components/TechBadge.astro';
import { personal } from '../data/personal';

const modules = ['NESTJS', 'SPRING BOOT', 'TYPESCRIPT', 'DOCKER', 'KAFKA', 'AWS'];
---

<section id="hero" class="min-h-screen flex items-center pt-20 pb-12 px-4 sm:px-6 lg:px-12">
  <div class="max-w-6xl mx-auto w-full grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
    <!-- Left Column -->
    <div class="space-y-5 sm:space-y-6 scroll-reveal">
      <!-- Kernel badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-dark-100 border border-dark-300 rounded-full">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-[10px] sm:text-xs font-mono text-muted" data-i18n="hero.kernel">
          SYSTEM.KERNEL :: v2026.03 ONLINE
        </span>
      </div>

      <!-- Main heading -->
      <div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
          <span class="text-foreground" data-i18n="hero.greeting">Hello, I'm</span>
          <br />
          <span class="text-gradient">{personal.name}</span>
        </h1>
        <p class="text-orange-400 font-mono text-base sm:text-lg mt-3" data-i18n="hero.tagline">
          &lt;Backend.Architect /&gt;
        </p>
      </div>

      <!-- Description -->
      <p class="text-muted text-sm sm:text-base leading-relaxed max-w-lg" data-i18n="hero.description">
        Software Engineering student with professional experience building backend and fullstack systems with NestJS, Spring Boot, and cloud infrastructure. Specialized in microservices, REST APIs, event-driven architecture, and scalable production backends.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-3 sm:gap-4">
        <a
          href="#about"
          class="group flex items-center gap-3 px-4 sm:px-5 py-3 bg-dark-100 border border-dark-300 rounded-xl hover:border-orange-500/40 transition-all"
        >
          <div class="flex flex-col">
            <span class="text-foreground text-sm font-semibold" data-i18n="hero.initializeOS">Initialize OS</span>
            <span class="text-muted text-xs font-mono" data-i18n="hero.bootCommand">$ boot --profile=developer</span>
          </div>
          <svg class="w-4 h-4 text-orange-400 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href={personal.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 sm:px-5 py-3 text-muted hover:text-foreground text-sm font-mono transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span data-i18n="hero.checkGithub">Check out GitHub</span>
        </a>
      </div>

      <!-- Loaded modules -->
      <div class="pt-2 sm:pt-4">
        <p class="text-muted text-xs font-mono mb-3" data-i18n="hero.loadedModules">LOADED_MODULES:</p>
        <div class="flex flex-wrap gap-2">
          {modules.map((mod) => <TechBadge name={mod} />)}
        </div>
      </div>
    </div>

    <!-- Right Column: Code Editor -->
    <div class="scroll-reveal scroll-reveal-delay-2">
      <CodeEditor />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:block">
    <a href="#about" class="flex flex-col items-center gap-2 text-muted hover:text-blue-400 transition-colors" aria-label="Scroll down">
      <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </a>
  </div>
</section>
