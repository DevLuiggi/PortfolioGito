---
import SectionHeading from '../components/SectionHeading.astro';
import { personal } from '../data/personal';
---

<section id="contact" class="min-h-screen py-20 sm:py-24 px-4 sm:px-6 lg:px-12">
  <div class="max-w-6xl mx-auto">
    <SectionHeading text="$ ./contact.exe" i18nKey="contact.title" />

    <div class="grid md:grid-cols-2 gap-4 sm:gap-6">
      <!-- Left: contact_info.json -->
      <div class="scroll-reveal">
        <div class="bg-dark-100 border border-dark-300 rounded-xl overflow-hidden card-glow h-full">
          <div class="flex items-center px-4 py-3 border-b border-dark-300 bg-dark-200">
            <div class="flex gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
            </div>
            <span class="flex-1 text-center text-muted text-xs sm:text-sm font-mono">contact_info.json</span>
            <div class="w-14"></div>
          </div>

          <div class="p-4 sm:p-6 font-mono text-xs sm:text-sm leading-relaxed overflow-x-auto">
            <div class="text-foreground whitespace-nowrap sm:whitespace-normal">
              <span class="text-dark-400 select-none mr-2 sm:mr-3">1</span><span class="text-syntax-keyword">{'{'}</span><br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">2</span>  <span class="text-syntax-type">"status"</span><span class="text-syntax-operator">:</span> <span class="text-syntax-string">"open_to_work"</span>,<br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">3</span>  <span class="text-syntax-type">"email"</span><span class="text-syntax-operator">:</span> <a href={`mailto:${personal.email}`} class="text-syntax-string hover:text-blue-400 transition-colors">"{personal.email}"</a>,<br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">4</span>  <span class="text-syntax-type">"socials"</span><span class="text-syntax-operator">:</span> <span class="text-syntax-keyword">{'{'}</span><br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">5</span>    <span class="text-syntax-type">"github"</span><span class="text-syntax-operator">:</span> <a href={personal.socials.github} target="_blank" rel="noopener noreferrer" class="text-syntax-string hover:text-blue-400 transition-colors">"@DevLuiggi"</a>,<br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">6</span>    <span class="text-syntax-type">"linkedin"</span><span class="text-syntax-operator">:</span> <a href={personal.socials.linkedin} target="_blank" rel="noopener noreferrer" class="text-syntax-string hover:text-blue-400 transition-colors">"@luiggipdeveloper"</a><br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">7</span>  <span class="text-syntax-keyword">{'}'}</span>,<br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">8</span>  <span class="text-syntax-type">"location"</span><span class="text-syntax-operator">:</span> <span class="text-syntax-string">"Lima, Peru"</span><br/>
              <span class="text-dark-400 select-none mr-2 sm:mr-3">9</span><span class="text-syntax-keyword">{'}'}</span>
            </div>
            <div class="mt-6 sm:mt-8 flex items-center gap-1 text-syntax-comment">
              <span data-i18n="contact.waiting">// Waiting for connection...</span>
              <span class="w-2 h-4 bg-green-500 animate-pulse ml-1"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: sendMessage.ts form -->
      <div class="scroll-reveal scroll-reveal-delay-2">
        <div class="bg-dark-100 border border-dark-300 rounded-xl overflow-hidden card-glow">
          <div class="flex items-center px-4 py-3 border-b border-dark-300 bg-dark-200">
            <div class="flex gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
            </div>
            <span class="flex-1 text-center text-muted text-xs sm:text-sm font-mono">sendMessage.ts</span>
            <div class="w-14"></div>
          </div>

          <form id="contact-form" class="p-4 sm:p-6 font-mono text-xs sm:text-sm space-y-3">
            <p class="text-syntax-comment" data-i18n="contact.formComment">// Run this script to send a message</p>
            <p><span class="text-syntax-keyword">const</span> <span class="text-syntax-function">send</span> = <span class="text-syntax-keyword">async</span> () <span class="text-syntax-operator">=&gt;</span> {'{'}</p>

            <div class="pl-2 sm:pl-4">
              <label class="block">
                <span class="text-syntax-keyword">const</span> <span class="text-syntax-type">name</span> <span class="text-syntax-operator">=</span>
                <input
                  type="text"
                  name="name"
                  required
                  class="ml-1 bg-dark-200 border border-dark-300 rounded px-3 py-1.5 text-syntax-string w-full mt-1 focus:border-blue-500/50 focus:outline-none transition-colors text-sm"
                  placeholder="Your name"
                  data-i18n="contact.namePlaceholder"
                />
              </label>
            </div>

            <div class="pl-2 sm:pl-4">
              <label class="block">
                <span class="text-syntax-keyword">const</span> <span class="text-syntax-type">email</span> <span class="text-syntax-operator">=</span>
                <input
                  type="email"
                  name="email"
                  required
                  class="ml-1 bg-dark-200 border border-dark-300 rounded px-3 py-1.5 text-syntax-string w-full mt-1 focus:border-blue-500/50 focus:outline-none transition-colors text-sm"
                  placeholder="your@email.com"
                  data-i18n="contact.emailPlaceholder"
                />
              </label>
            </div>

            <div class="pl-2 sm:pl-4">
              <label class="block">
                <span class="text-syntax-keyword">const</span> <span class="text-syntax-type">phone</span> <span class="text-syntax-operator">=</span>
                <div class="flex gap-1.5 mt-1">
                  <div class="relative shrink-0">
                    <select
                      name="countryCode"
                      class="appearance-none bg-dark-200 border border-dark-300 rounded pl-2 pr-6 py-1.5 text-syntax-string focus:border-blue-500/50 focus:outline-none transition-colors text-sm cursor-pointer"
                      style="min-width: 5.5rem;"
                    >
                      <option value="+51">&#127477;&#127466; +51</option>
                      <option value="+1">&#127482;&#127480; +1</option>
                      <option value="+52">&#127474;&#127485; +52</option>
                      <option value="+54">&#127462;&#127479; +54</option>
                      <option value="+55">&#127463;&#127479; +55</option>
                      <option value="+56">&#127464;&#127473; +56</option>
                      <option value="+57">&#127464;&#127476; +57</option>
                      <option value="+58">&#127483;&#127466; +58</option>
                      <option value="+591">&#127463;&#127476; +591</option>
                      <option value="+593">&#127466;&#127464; +593</option>
                      <option value="+595">&#127477;&#127486; +595</option>
                      <option value="+598">&#127482;&#127486; +598</option>
                      <option value="+34">&#127466;&#127480; +34</option>
                      <option value="+44">&#127468;&#127463; +44</option>
                    </select>
                    <span class="pointer-events-none absolute right-1.5 top-1/2 -translate-y-1/2 text-muted text-xs leading-none">&#9662;</span>
                  </div>
                  <input
                    type="tel"
                    name="phoneNumber"
                    class="bg-dark-200 border border-dark-300 rounded px-3 py-1.5 text-syntax-string flex-1 min-w-0 focus:border-blue-500/50 focus:outline-none transition-colors text-sm"
                    placeholder="Phone number (optional)"
                    data-i18n="contact.phonePlaceholder"
                  />
                </div>
              </label>
            </div>

            <p class="pl-2 sm:pl-4"><span class="text-syntax-keyword">await</span> api.<span class="text-syntax-function">submit</span>({'{'}</p>
            <p class="pl-4 sm:pl-6" data-i18n="contact.nameEmail">name, email, phone,</p>
            <div class="pl-4 sm:pl-6">
              <label class="block">
                <span class="text-syntax-type">message</span><span class="text-syntax-operator">:</span>
                <textarea
                  name="message"
                  required
                  rows="3"
                  class="bg-dark-200 border border-dark-300 rounded px-3 py-1.5 text-syntax-string w-full mt-1 focus:border-blue-500/50 focus:outline-none transition-colors resize-none text-sm"
                  placeholder="Your message..."
                  data-i18n="contact.messagePlaceholder"
                ></textarea>
              </label>
            </div>
            <p class="pl-2 sm:pl-4">{'}'})</p>
            <p>{'}'}</p>

            <button
              type="submit"
              class="flex items-center gap-2 px-5 sm:px-6 py-2.5 sm:py-3 bg-orange-500/10 border border-orange-500/40 rounded-lg text-orange-400 font-mono hover:bg-orange-500/20 hover:border-orange-500/60 transition-all mt-4 w-full justify-center text-sm"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              <span data-i18n="contact.runScript">RUN SCRIPT</span>
            </button>

          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Toast container -->
<div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

<script>
  import { langStore } from '../i18n/languageStore';

  const toastTexts = {
    en: {
      success: '// Message sent successfully!',
      error: '// Failed to send message. Try again.',
      networkError: '// Network error. Try again.',
    },
    es: {
      success: '// ¡Mensaje enviado exitosamente!',
      error: '// Error al enviar mensaje. Intenta de nuevo.',
      networkError: '// Error de red. Intenta de nuevo.',
    },
  };

  function showToast(type: 'success' | 'error', customMessage?: string) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const lang = langStore.current;
    const t = toastTexts[lang];
    const message = customMessage || (type === 'success' ? t.success : t.error);

    const isSuccess = type === 'success';
    const borderColor = isSuccess ? '#22c55e' : '#ef4444';
    const iconColor = isSuccess ? '#22c55e' : '#ef4444';
    const timeout = isSuccess ? 4000 : 6000;

    const toast = document.createElement('div');
    toast.className = 'pointer-events-auto';
    toast.style.animation = 'toast-in 0.35s ease-out forwards';

    toast.innerHTML = `
      <div style="display:flex;align-items:center;gap:12px;background:#1e1e22;border:1px solid #2d2d33;border-left:3px solid ${borderColor};border-radius:10px;padding:14px 18px;min-width:280px;max-width:420px;box-shadow:0 8px 32px rgba(0,0,0,0.4);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="${iconColor}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
          ${isSuccess
            ? '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>'
            : '<circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>'
          }
        </svg>
        <span style="font-family:var(--font-mono);font-size:13px;color:${isSuccess ? '#7ee787' : '#ff7b72'}; flex:1;">${message}</span>
        <button aria-label="Close" style="background:none;border:none;color:#8b8fa3;cursor:pointer;padding:2px;line-height:1;font-size:16px;">&#10005;</button>
      </div>
    `;

    const closeBtn = toast.querySelector('button')!;
    let dismissed = false;

    function dismiss() {
      if (dismissed) return;
      dismissed = true;
      toast.style.animation = 'toast-out 0.3s ease-in forwards';
      toast.addEventListener('animationend', () => toast.remove());
    }

    closeBtn.addEventListener('click', dismiss);

    container.appendChild(toast);

    setTimeout(dismiss, timeout);
  }

  const form = document.getElementById('contact-form') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const countryCode = (data.get('countryCode') as string) ?? '';
    const phoneNumber = ((data.get('phoneNumber') as string) ?? '').trim();
    const phone = phoneNumber ? `${countryCode} ${phoneNumber}` : undefined;

    const body = {
      name: data.get('name'),
      email: data.get('email'),
      message: data.get('message'),
      ...(phone ? { phone } : {}),
      lang: document.documentElement.lang || 'en',
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        showToast('success');
        form.reset();
      } else {
        const err = await res.json();
        const lang = langStore.current;
        const t = toastTexts[lang];
        showToast('error', `// Error: ${err.error || t.error}`);
      }
    } catch {
      const lang = langStore.current;
      showToast('error', toastTexts[lang].networkError);
    }
  });
</script>
