---
import SectionHeading from '../components/SectionHeading.astro';
import { Image } from 'astro:assets';
import profileImg from '../assets/LuiggiP.jpg';
---

<section id="about" class="min-h-screen py-20 sm:py-24 px-4 sm:px-6 lg:px-12">
  <div class="max-w-6xl mx-auto">
    <SectionHeading text="# About.system" i18nKey="about.title" />

    <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-start">
      <!-- Photo Card -->
      <div class="scroll-reveal">
        <div class="bg-dark-100 border border-dark-300 rounded-xl p-5 sm:p-6 card-glow">
          <div class="flex justify-center mb-6">
            <div class="relative">
              <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden ring-2 ring-blue-500/40 ring-offset-4 ring-offset-dark-100">
                <Image
                  src={profileImg}
                  alt="Luiggi Paredes"
                  width={160}
                  height={160}
                  class="w-full h-full object-cover"
                />
              </div>
              <span class="absolute bottom-2 right-2 w-4 h-4 rounded-full bg-green-500 border-2 border-dark-100"></span>
            </div>
          </div>

          <div class="space-y-3 font-mono text-xs sm:text-sm">
            <div class="flex justify-between items-center py-2 border-b border-dark-300">
              <span class="text-muted" data-i18n="about.operator">OPERATOR</span>
              <span class="text-orange-400 font-semibold text-xs sm:text-sm">LUIGGI PAREDES</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-dark-300">
              <span class="text-muted" data-i18n="about.role">ROLE</span>
              <span class="text-foreground text-[10px] sm:text-xs" data-i18n="about.roleValue">BACKEND_FULLSTACK_ENGINEER</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-dark-300">
              <span class="text-muted" data-i18n="about.location">LOCATION</span>
              <span class="text-foreground" data-i18n="about.locationValue">Lima, Peru</span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-muted" data-i18n="about.status">STATUS</span>
              <span class="inline-flex items-center gap-1.5 px-2 py-0.5 bg-green-500/10 border border-green-500/30 rounded text-green-500 text-xs">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                <span data-i18n="about.statusValue">OPEN_TO_WORK</span>
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Terminal Block -->
      <div class="scroll-reveal scroll-reveal-delay-2">
        <div class="bg-dark-100 border border-dark-300 rounded-xl overflow-hidden card-glow">
          <div class="flex items-center px-4 py-3 border-b border-dark-300 bg-dark-200">
            <div class="flex gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
            </div>
            <span class="flex-1 text-center text-muted text-xs sm:text-sm font-mono">user_profile.log</span>
            <div class="w-14"></div>
          </div>

          <div class="p-4 sm:p-6 font-mono text-xs sm:text-sm space-y-5 sm:space-y-6">
            <div>
              <p class="text-blue-400 mb-2" data-i18n="about.whoami">&gt; whoami</p>
              <p class="text-muted leading-relaxed" data-i18n="about.whoamiResponse">
                I'm Luiggi Paredes, a Software Engineering student from Lima, Peru, with hands-on experience building production-grade backend systems.
              </p>
            </div>

            <div>
              <p class="text-blue-400 mb-2" data-i18n="about.catMission">&gt; cat mission.txt</p>
              <p class="text-muted leading-relaxed" data-i18n="about.missionResponse">
                My mission is to architect scalable <strong class="text-orange-400">microservices</strong>, leverage <strong class="text-blue-400">cloud infrastructure</strong>, and build robust <strong class="text-green-500">event-driven systems</strong>. Currently focused on <strong class="text-orange-400">SUNAT electronic billing</strong> and enterprise-grade backend solutions.
              </p>
            </div>

            <div class="flex items-center gap-1">
              <span class="text-green-500">&gt;</span>
              <span class="w-2 h-4 bg-green-500 animate-pulse"></span>
            </div>
          </div>
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-2 sm:gap-3 mt-4">
          <!-- Experience -->
          <div class="bg-dark-100 border border-dark-300 rounded-lg p-3 sm:p-4 card-glow">
            <div class="flex items-center gap-1.5 mb-2">
              <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
              <span class="text-muted text-[10px] sm:text-xs font-mono uppercase" data-i18n="about.experienceLabel">EXPERIENCE</span>
            </div>
            <div class="flex items-baseline gap-1.5">
              <span class="text-foreground font-mono text-xl sm:text-2xl font-bold">2+</span>
              <span class="text-muted font-mono text-[10px] sm:text-xs" data-i18n="about.experienceUnit">YRS</span>
            </div>
          </div>
          <!-- Projects -->
          <div class="bg-dark-100 border border-dark-300 rounded-lg p-3 sm:p-4 card-glow">
            <div class="flex items-center gap-1.5 mb-2">
              <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25" />
              </svg>
              <span class="text-muted text-[10px] sm:text-xs font-mono uppercase" data-i18n="about.projectsLabel">PROJECTS</span>
            </div>
            <div class="flex items-baseline gap-1.5">
              <span class="text-foreground font-mono text-xl sm:text-2xl font-bold">10+</span>
              <span class="text-muted font-mono text-[10px] sm:text-xs" data-i18n="about.projectsUnit">DEP</span>
            </div>
          </div>
          <!-- Caffeine -->
          <div class="bg-dark-100 border border-dark-300 rounded-lg p-3 sm:p-4 card-glow">
            <div class="flex items-center gap-1.5 mb-2">
              <svg class="w-3.5 h-3.5 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 8h1a4 4 0 1 1 0 8h-1" /><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z" /><line x1="6" y1="2" x2="6" y2="4" /><line x1="10" y1="2" x2="10" y2="4" /><line x1="14" y1="2" x2="14" y2="4" />
              </svg>
              <span class="text-muted text-[10px] sm:text-xs font-mono uppercase" data-i18n="about.caffeineLabel">CAFFEINE</span>
            </div>
            <div class="flex items-baseline gap-1.5">
              <span class="text-foreground font-mono text-xl sm:text-2xl font-bold">&infin;</span>
              <span class="text-muted font-mono text-[10px] sm:text-xs">ml</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
