---
import SectionHeading from '../components/SectionHeading.astro';
import TechBadge from '../components/TechBadge.astro';
import { projects } from '../data/projects';
---

<section id="projects" class="min-h-screen py-20 sm:py-24 px-4 sm:px-6 lg:px-12">
  <div class="max-w-6xl mx-auto">
    <SectionHeading text="$ ls -la ~/projects" i18nKey="projects.title" />

    <div class="grid md:grid-cols-2 gap-4 sm:gap-6">
      {projects.map((project, idx) => (
        <div class={`scroll-reveal ${idx > 0 ? `scroll-reveal-delay-${Math.min(idx, 3)}` : ''} ${idx === 0 ? 'md:col-span-2' : ''}`}>
          <div class="bg-dark-100 border border-dark-300 rounded-xl overflow-hidden card-glow group h-full flex flex-col">
            {/* Project cover */}
            <div class="relative h-36 sm:h-48 overflow-hidden bg-gradient-to-br from-dark-200 via-dark-100 to-dark-200">
              <div class="absolute inset-0 opacity-20" style={`background: linear-gradient(135deg, ${idx === 0 ? 'rgba(0,102,255,0.3)' : idx === 1 ? 'rgba(255,107,0,0.3)' : 'rgba(34,197,94,0.3)'}, transparent);`}></div>
              <span class="absolute top-4 left-4 text-5xl sm:text-6xl font-bold text-foreground/5 font-mono">{project.number}</span>
              <div class="absolute top-3 right-3 sm:top-4 sm:right-4 flex items-center gap-2">
                <span class="px-2 py-0.5 text-[10px] font-mono border border-orange-500/30 text-orange-400 bg-orange-500/10 rounded" data-en={project.type.en} data-es={project.type.es}>
                  {project.type.en}
                </span>
                <span class="px-2 py-0.5 text-[10px] font-mono border border-green-500/30 text-green-500 bg-green-500/10 rounded" data-i18n="projects.public">
                  Public
                </span>
              </div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-24 h-24 sm:w-32 sm:h-32 border border-dark-400/30 rounded-2xl rotate-12 group-hover:rotate-6 transition-transform duration-500"></div>
                <div class="absolute w-16 h-16 sm:w-24 sm:h-24 border border-dark-400/20 rounded-xl -rotate-6 group-hover:rotate-3 transition-transform duration-500"></div>
              </div>
            </div>

            {/* Content */}
            <div class="p-4 sm:p-6 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-1">
                <svg class="w-4 h-4 text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
                </svg>
                <h3 class="text-lg sm:text-xl font-bold text-foreground">{project.name}</h3>
              </div>
              <p class="text-muted text-xs sm:text-sm leading-relaxed mb-4 flex-1" data-en={project.description.en} data-es={project.description.es}>
                {project.description.en}
              </p>

              <ul class="space-y-1 mb-4">
                {project.features.en.map((feature, fIdx) => (
                  <li class="flex items-start gap-2 text-[11px] sm:text-xs text-muted font-mono">
                    <span class="text-green-500 shrink-0 mt-0.5">+</span>
                    <span data-en={feature} data-es={project.features.es[fIdx]}>{feature}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5 mb-4 sm:mb-5">
                {project.tech.map((t) => <TechBadge name={t} />)}
              </div>

              <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between pt-4 border-t border-dark-300 gap-3">
                <div class="flex items-center gap-4 text-xs text-muted font-mono">
                  <span class="flex items-center gap-1">
                    <span class={`w-2.5 h-2.5 rounded-full ${idx === 0 ? 'bg-blue-400' : idx === 1 ? 'bg-yellow-500' : 'bg-green-500'}`}></span>
                    {project.language}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
                    {project.stars}
                  </span>
                </div>
                <div class="flex gap-2">
                  {project.repoUrl && (
                    <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 text-xs font-mono text-muted border border-dark-300 rounded-lg hover:text-foreground hover:border-dark-400 transition-all" data-i18n="projects.repo">
                      Source Code
                    </a>
                  )}
                  {project.demoUrl && (
                    <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 text-xs font-mono text-blue-400 bg-blue-500/10 border border-blue-500/30 rounded-lg hover:bg-blue-500/20 transition-all" data-i18n="projects.demo">
                      Live Demo
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
