---
import SectionHeading from '../components/SectionHeading.astro';
import TechBadge from '../components/TechBadge.astro';
import { experience } from '../data/experience';
---

<section id="experience" class="min-h-screen py-20 sm:py-24 px-4 sm:px-6 lg:px-12">
  <div class="max-w-6xl mx-auto">
    <SectionHeading text="$ git log --stat --oneline" i18nKey="experience.title" />

    <div class="relative">
      <div class="absolute left-1/2 top-0 bottom-0 w-px bg-dark-300 hidden lg:block" aria-hidden="true"></div>
      <div class="absolute left-4 top-0 bottom-0 w-px bg-dark-300 lg:hidden" aria-hidden="true"></div>

      {experience.map((entry, idx) => {
        const isLeft = idx % 2 === 0;

        const cardContent = (
          <div class="bg-dark-100 border border-dark-300 rounded-xl p-5 lg:p-6 card-glow">
            <div class="flex flex-wrap items-center gap-2 mb-3 font-mono text-xs">
              <span class="text-orange-400">{entry.hash}</span>
              <span class="border border-blue-500/30 text-blue-400 px-2 py-0.5 rounded text-[10px]">
                {entry.branch}
              </span>
              <span class="text-muted ml-auto hidden sm:inline">{entry.company}</span>
            </div>
            <h3 class="text-base lg:text-lg font-bold mb-2">
              <span data-en={entry.role.en} data-es={entry.role.es}>{entry.role.en}</span>
              <span class="text-muted font-normal text-xs sm:text-sm"> @ {entry.company}</span>
            </h3>
            <p class="font-mono text-muted text-xs leading-relaxed mb-4 border-l-2 border-dark-400 pl-3" data-en={entry.description.en} data-es={entry.description.es}>
              {entry.description.en}
            </p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {entry.tech.map((t) => <TechBadge name={t} />)}
            </div>
            <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-[10px] sm:text-[11px] font-mono text-muted">
              <span>{entry.stats.files} <span data-i18n="experience.filesChanged">files changed</span></span>
              <span class="text-green-500">+{entry.stats.insertions} <span data-i18n="experience.insertions">insertions</span></span>
              <span class="text-red-500">-{entry.stats.deletions} <span data-i18n="experience.deletions">deletions</span></span>
            </div>
          </div>
        );

        return (
          <div class={`relative mb-12 lg:mb-16 scroll-reveal ${idx > 0 ? `scroll-reveal-delay-${Math.min(idx, 3)}` : ''}`}>
            {/* Desktop: alternating layout */}
            <div class="hidden lg:grid grid-cols-[1fr_auto_1fr] gap-8">
              {isLeft ? cardContent : <div></div>}

              <div class="flex flex-col items-center pt-6">
                <div class="w-4 h-4 rounded-full border-2 border-orange-500 bg-dark-bg z-10"></div>
                <span class="bg-dark-100 border border-dark-300 px-3 py-1 rounded-full text-[10px] font-mono text-muted mt-2 whitespace-nowrap" data-en={entry.dateRange.en} data-es={entry.dateRange.es}>
                  {entry.dateRange.en}
                </span>
              </div>

              {!isLeft ? cardContent : <div></div>}
            </div>

            {/* Mobile/Tablet: left-aligned */}
            <div class="lg:hidden flex gap-4 sm:gap-6">
              <div class="flex flex-col items-center shrink-0">
                <div class="w-3 h-3 rounded-full border-2 border-orange-500 bg-dark-bg z-10"></div>
              </div>
              <div class="flex-1 bg-dark-100 border border-dark-300 rounded-xl p-4 sm:p-5 card-glow">
                <div class="flex flex-wrap items-center gap-2 mb-3 font-mono text-xs">
                  <span class="text-orange-400">{entry.hash}</span>
                  <span class="border border-blue-500/30 text-blue-400 px-2 py-0.5 rounded text-[10px]">
                    {entry.branch}
                  </span>
                </div>
                <p class="text-muted text-[10px] font-mono mb-2" data-en={entry.dateRange.en} data-es={entry.dateRange.es}>{entry.dateRange.en}</p>
                <h3 class="text-sm sm:text-base font-bold mb-2">
                  <span data-en={entry.role.en} data-es={entry.role.es}>{entry.role.en}</span>
                  <span class="text-muted font-normal text-xs block">{entry.company}</span>
                </h3>
                <p class="font-mono text-muted text-xs leading-relaxed mb-3 border-l-2 border-dark-400 pl-3" data-en={entry.description.en} data-es={entry.description.es}>
                  {entry.description.en}
                </p>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {entry.tech.map((t) => <TechBadge name={t} />)}
                </div>
                <div class="flex flex-wrap items-center gap-2 sm:gap-3 text-[10px] font-mono text-muted">
                  <span>{entry.stats.files} <span data-i18n="experience.filesChanged">files changed</span></span>
                  <span class="text-green-500">+{entry.stats.insertions} <span data-i18n="experience.insertions">insertions</span></span>
                  <span class="text-red-500">-{entry.stats.deletions} <span data-i18n="experience.deletions">deletions</span></span>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
