<!-- Fixed grid overlay + cursor glow -->
<div
  class="fixed inset-0 pointer-events-none z-0"
  style="background-image: linear-gradient(rgba(0,102,255,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,102,255,0.06) 1px, transparent 1px); background-size: 40px 40px;"
  aria-hidden="true"
></div>

<!-- Cursor-following glow -->
<div
  id="cursor-glow"
  class="fixed w-80 h-80 rounded-full pointer-events-none z-0 hidden lg:block opacity-60"
  style="background: radial-gradient(circle, rgba(0,102,255,0.1) 0%, transparent 70%); transform: translate(-50%, -50%); left: -100px; top: -100px;"
  aria-hidden="true"
></div>
